{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "WebApi (https)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/backend/SarvashresthaCMS.WebApi/bin/Debug/net8.0/SarvashresthaCMS.WebApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/SarvashresthaCMS.WebApi",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "launchSettingsProfile": "https",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "WebApi (http)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/backend/SarvashresthaCMS.WebApi/bin/Debug/net8.0/SarvashresthaCMS.WebApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/SarvashresthaCMS.WebApi",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "launchSettingsProfile": "http",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
