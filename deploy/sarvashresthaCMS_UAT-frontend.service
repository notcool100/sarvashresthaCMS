[Unit]
Description=sarvashresthaCMS_UAT Frontend (SvelteKit)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/sarvashresthaCMS_UAT/frontend/build
Environment=NODE_ENV=production
Environment=PORT=3200
ExecStart=/usr/bin/node index.js
Restart=on-failure

[Install]
WantedBy=multi-user.target
